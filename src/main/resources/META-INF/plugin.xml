<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.kldo.deepseek-sync</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Deepseek-Sync</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>KL_Taekwondo</vendor>
    <version>0.1.1</version>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Bring DeepSeek Web Chat into your IDE.<br>
        No more switching between browser and editor — just open the side panel, log in, and start chatting.

        <br><b>Highlights:</b>
        <ul>
            <li>Embedded DeepSeek Web Chat in a side tool window</li>
            <li>One-click access without leaving the IDE</li>
            <li>Stay in flow and get answers faster</li>
            <li>Support DeepSeek Platform in the IDE side panel</li>
        </ul>

        <br><b>中文介绍：</b>
        <ul>
            <li>将 DeepSeek 网页版带入你的 IDE</li>
            <li>无需切换浏览器，侧边栏直接对话</li>
            <li>保持编码心流，更快获得帮助</li>
            <li>支持查看DeepSeek Platform 数据</li>
        </ul>
]]></description>

    <change-notes><![CDATA[
        <b>0.1.1</b> - Initial release
        <ul>
            <li>support DeepSeek Platform in the IDE side panel</li>
            <li>support refresh the browser</li>
            <li>support All the JetBrains IDE(Maybe)</li>
        </ul>

        <br><b>0.1.1</b> - 最初版发布
        <ul>
            <li>支持查看DeepSeek Platform 数据</li>
            <li>支持刷新浏览器</li>
            <li>支持所有 JetBrains IDE(Maybe)</li>
        </ul>
    ]]></change-notes>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>com.intellij.modules.lsp</depends>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="DeepSeek-Sync/深度同步"
                    factoryClass="com.kldo.DeepSeekSyncFactory"
                    icon="/META-INF/icon.svg"/>
        <notificationGroup id="DeepSeek-Sync"
                           displayType="BALLOON" bundle="messages.MyMessageBundle"
                           key="notification.group.deepseek-sync"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>